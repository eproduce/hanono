{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Hanono",
  "version": "0.3.2",
  "identifier": "com.hanono.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Hanono",
        "width": 1100,
        "height": 700,
        "minWidth": 600,
        "minHeight": 400,
        "hiddenTitle": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": "default-src 'self' blob:; img-src 'self' blob: asset: https://asset.localhost; media-src 'self' asset: https://asset.localhost blob:; style-src 'self' 'unsafe-inline'; connect-src 'self' blob:",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {},
    "copyright": "© 2026 Hanono",
    "category": "Music",
    "shortDescription": "沉浸式音乐播放器",
    "longDescription": "Hanono - 沉浸式本地音乐播放器，支持 FLAC/MP3/WAV/OGG 等主流格式。"
  }
}
